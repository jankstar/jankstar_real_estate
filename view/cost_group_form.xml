<?xml version="1.0"?>
<form col="6" >
    <group col="-1" colspan="6" id="cost_group_active">
        <label name="active"/><field name="active" xexpand="0" width="15"/>
        <label name="id"/><field name="id" readonly="1" xexpand="0" width="15"/>
        <label name="description"/><field name="description"/>
    </group>
    <newline/>
    <group col="4" id="cost_group_general">
        <label name="company"/><field name="company"/>
        <label name="property"/><field name="property"/>
        <newline/>
        <label name="start_date" /><field name="start_date"/>
        <label name="end_date" /><field name="end_date"/>
        <newline/>
        <label name="state"/><field name="state"/>
    </group>
    <label name="term_types_of_use"/><field name="term_types_of_use"/>
    <newline/>
    <group colspan="8" col="-1" id="cost_groups">
        <field name="cost_objects"/>
    </group>
</form>