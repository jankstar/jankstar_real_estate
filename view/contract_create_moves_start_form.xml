<?xml version="1.0"?>
<form col="10" >
    <!--image name="tryton-question" xexpand="0" xfill="0"/-->
    <group col="4" id="gr01" homogeneous="1" string="Selection">
        <label name="company"/><field name="company" colspan="1"/>
        <newline/>
        <label name="propertys" string=" " /><field name="propertys" colspan="1" width="200"/>
        <newline/>
        <label name="contracts" string=" " /><field name="contracts" colspan="1" width="200"/>
    </group>
    <newline/>    
    <group col="4" id="gr02" homogeneous="1" string="Execution">
        <label name="date"/><field name="date"/>
        <newline/>
        <label name="action"/><field name="action" colspan="1"/>
        <newline/>
        <label name="invoice_date"/><field name="invoice_date" colspan="1"/>
        <field name="invoice_date_in_past" invisible="1"/>
        <newline/>
        <label string=""
            colspan="4"
            states='{"invisible": {"__class__": "Not", "v": {"__class__": "Eval", "v": "invoice_date_in_past", "d": false}}}'/>
        <label string="Achtung: Buchung in die Vergangenheit - strikte inkrementelle Buchung beachten."
            colspan="4"
            states='{"invisible": {"__class__": "Not", "v": {"__class__": "Eval", "v": "invoice_date_in_past", "d": false}}}'/>
        <newline/>
        <label name="invoice_state"/><field name="invoice_state" colspan="1"/>
        <newline/>
        <label name="execute_in_queue"/><field name="execute_in_queue" colspan="1"/>
    </group>
</form>