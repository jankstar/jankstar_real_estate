<?xml version="1.0"?>
<form col="6">
    <label name="name"/><field name="name" colspan="3" readonly="1"/>
    <label name="c_type"/><field name="c_type"/>
    <newline/>   

    <label name="contractual_partner"/><field name="contractual_partner"/>
    <label name="company"/><field name="company"/>
    <label name="property"/><field name="property"/>
    <newline/>   

    <label name="id"/><field name="id" readonly="1"/>
    <label name="sequence"/><field name="sequence"/>
    <label name="contract_number"/><field name="contract_number" readonly="1"/>
    <newline/>   

    <label name="type_of_use"/><field name="type_of_use"/>
    <label name="currency"/><field name="currency"/>
    <newline/>   

    <label name="start_date"/><field name="start_date"/>
    <label name="end_date"/><field name="end_date"/>
    <group colspan="2" col="-1" id="checkboxes">
        <label name="active"/><field name="active" xexpand="0" width="25"/>
        <label name="state"/><field name="state" widget="selection"/>
    </group>  
    <newline/>   
    <notebook colspan="8">
        <page string="General" id="page_general" col="6">
            <newline/>
            
            <label name="payment_term"/><field name="payment_term"/>
            <newline/>   
            <label name="invoice_address"/><field name="invoice_address"/>
            <label name="phone_partner"/><field name="phone_partner" readonly="1"/>
            <newline/>   
            <label name="date_of_signature"/><field name="date_of_signature"/>

            <separator name="comment" colspan="6"/>
            <field name="comment" colspan="6"/>
        </page>
        <page string="Termination" id="page_termination" col="6">
            <newline/>
            <label name="terminated_by_type"/><field name="terminated_by_type"/>
            <newline/>
            <label name="receipt_of_termination_notice"/><field name="receipt_of_termination_notice"/>
            <newline/>
            <label name="termination_reason"/><field name="termination_reason"/>
            <newline/>
            <label name="termination_notice"/><field name="termination_notice" widget="selection"/>
            <newline/>
            <label name="termination_date"/><field name="termination_date"/>
        </page>
        <page string="Items" id="page_items" col="6">
            <newline/>
            <field name="items" 
                view_ids="real_estate.contract_view_list_object_item"/> 
        </page>
        <page string="Terms" id="page_terms">
            <!--group colspan="2" col="-1" id="next_term_sequence_group">
                <label name="next_term_sequence"/><field name="next_term_sequence"/>
            </group-->
            <newline/>
            <field name="terms" 
                view_ids="real_estate.contract_view_list_object_term"/>        
        </page>
        <page string="Cash Flow" id="page_cash_flow">
            <newline/>
            <notebook colspan="8">

                <page string="Draft" id="page_cash_flow_draft">
                    <field name="cash_flow_draft" 
                        view_ids="real_estate.contract_view_list_cash_flow" />
                </page>

                <page string="Posted" id="page_cash_flow_posted">
                    <field name="cash_flow_posted" />
                </page>
                <page string="Paid" id="page_cash_flow_paid">
                    <field name="cash_flow_paid" />
                <!-- view_ids="real_estate.contract_view_list_cash_flow"
                    /-->
                </page>

            </notebook>
        </page>
        <page string="Measurements" id="page_measurements">
            <newline/>
            <field name="measurements"
                view_ids="real_estate.contract_view_list_measurement"/>
        </page>          
        <page string="Meters" id="page_meters">
            <newline/>
            <field name="meters" />
        </page>        
    </notebook>
    <newline/>
    <button name="running" string="Running"/>
    <button name="terminate" string="Terminate"/>
    <button name="cancel" string="Cancel"/>
    <button name="change_partner" string="Change Partner"/>
    <button name="open_party_ledger" string="Party Ledger"/>

</form>