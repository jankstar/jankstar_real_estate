<?xml version="1.0"?>
<form col="6" >
    <group colspan="4" id="settlement_unit_active">
        <label name="active"/><field name="active" xexpand="0" width="15"/>
        <label name="id"/><field name="id" readonly="1" xexpand="0" width="15"/>
        <label name="sequence"/><field name="sequence"/>
        <label name="name"/><field name="name"/>
    </group>
    <group colspan="2" id="settlement_unit_state">
        <label name="state"/><field name="state"/>
        <newline/>
        <label name="sub_state"/><field name="sub_state"/>
    </group>

    <newline/>
    <label name="company"/><field name="company"/>
    <label name="property"/><field name="property"/>
    <label name="billing_unit"/><field name="billing_unit"/>
    <newline/>
    <label name="start_date" /><field name="start_date"/>
    <label name="end_date" /><field name="end_date"/>
    <label name="type"/><field name="type"/>
    <newline/>
    <label name="allocation_rule"/><field name="allocation_rule"/>
    <label name="vacancy"/><field name="vacancy"/>
    <label name="m_type"/><field name="m_type"/>
    <label name="meter_unit"/><field name="meter_unit"/>
    <label name="reg_ex_object"/><field name="reg_ex_object"/>
    <label name="reg_ex_meter"/><field name="reg_ex_meter"/>
    <newline/>
    <label name="planned_costs"/><field name="planned_costs"/>
    <label name="currency"/><field name="currency"/>
    <newline/>   
    <separator name="comment" colspan="4"/><field name="comment" colspan="4"/>
    <newline/>
    <group colspan="8"  id="settlement_unit_base_objects">
        <field name="objects"/>
    </group>
     <group colspan="8"  id="settlement_unit_base_meters">
        <field name="meters"/>
    </group>
    <group colspan="8"  id="settlement_unit_base_measurements">
        <field name="measurements"/>
    </group>
        <group colspan="8"  id="settlement_unit_base_cost_shares">
        <field name="cost_shares"/>
    </group>

</form>